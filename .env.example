# E-Bog'cha local environment template
# Copy to .env. Never commit the resulting .env file.

# Application
APP_NAME=e-bogcha
APP_ENV=local
APP_PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=e_bogcha
DB_USER=e_bogcha
DB_PASSWORD=replace-with-a-local-password
DB_SCHEMA=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-a-local-password

# JWT
# Use a cryptographically random value of sufficient length.
# Must decode from Base64 to at least 32 bytes.
JWT_SECRET_BASE64=replace-with-a-base64-encoded-random-secret-at-least-32-bytes
JWT_ACCESS_EXPIRATION_SECONDS=900
JWT_REFRESH_EXPIRATION_SECONDS=2592000
JWT_ISSUER=e-bogcha
JWT_AUDIENCE=e-bogcha-web

# Authentication
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_SECONDS=900
AUTH_COOKIE_SECURE=false
DEV_ACTOR_HEADER_ENABLED=false

# Object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=replace-with-a-local-access-key
MINIO_SECRET_KEY=replace-with-a-local-secret-key
MINIO_BUCKET=e-bogcha

# SMTP — optional during local development
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Logging
LOG_LEVEL=INFO

# Telephony — leave empty until Grandstream integration is configured
PBX_BASE_URL=
PBX_USERNAME=
PBX_PASSWORD=
PBX_WEBHOOK_SECRET=
